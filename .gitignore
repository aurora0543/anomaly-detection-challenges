# ==============================================================================
# Anomaly Detection Challenges - Git Ignore Configurations
# ==============================================================================

# macOS system files
.DS_Store
.AppleDouble
.LSOverride
Icon\r
._*

# Python cache & build files
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
pip-log.txt
pip-delete-this-directory.txt

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# IDE and Editor configurations
.vscode/
.idea/
*.swp
*.swo
*~

# MS Office temporary files
~$*.docx
~$*.xlsx

# ==============================================================================
# Project Specific Exclusions (Datasets, Models, & Output Results)
# ==============================================================================

# 1. Ignore Datasets
/datasets/*
**/datasets/*
**/data/*
**/huafang_raw/*
!/datasets/download_dataset.py

# 2. Ignore Model Weights and Checkpoints (Any deep learning weight formats)
*.pt
*.pth
*.onnx
*.ckpt
*.pb
*.h5
*.weights
*.bin
**/checkpoints/
**/weights/
**/exports/

# 3. Ignore Training Runs, Reports and Benchmark Output Results
**/results/
**/runs/
**/results_dir/
**/reports/
*.log
logs/
*.csv
*.png
*.jpg
*.jpeg
